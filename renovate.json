{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>lasuillard-s/renovate-config"
  ],
  "ignorePaths": [
    "examples/**"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "pep621"
      ],
      "matchJsonata": [
        "managerData.depGroup != 'dev'"
      ],
      "rangeStrategy": "widen"
    }
  ]
}
